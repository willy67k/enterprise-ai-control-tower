# Copy to `.env` and adjust. Loaded by pydantic-settings (see app/config.py).

APP_NAME=Enterprise AI Control Tower
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# PostgreSQL (match docker-compose.yml)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/control_tower
DATABASE_ECHO=false

# Phase 3 dev token (Authorization: Bearer … or X-API-Token)
DEV_API_TOKEN=dev-insecure-change-me

# Phase 4 — LLM (set keys for providers you use)
# Default provider when request omits "provider": openai | gemini | anthropic
DEFAULT_LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (https://aistudio.google.com/apikey) — GOOGLE_API_KEY or GEMINI_API_KEY
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Phase 5 — uploads & RAG (OpenAI embeddings → VECTOR(1536))
UPLOAD_DIR=data/uploads
MAX_UPLOAD_BYTES=10485760
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Marker PDF → markdown (optional; default device from torch). Example: cuda, cpu
MARKER_DEVICE=

# Phase 8 — LangSmith (https://smith.langchain.com/) — traces, per-step latency, token usage
# LANGCHAIN_API_KEY and LANGSMITH_API_KEY are both accepted (see app/config.py).
LANGCHAIN_API_KEY=
# Set false to keep key in .env but disable sending traces
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=
# Optional EU endpoint: https://eu.api.smith.langchain.com
# LANGCHAIN_ENDPOINT=
